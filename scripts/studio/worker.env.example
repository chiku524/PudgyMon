# Recommended Immersive Studio worker settings for ShipHappens (Tripo + Godot).
# Copy values into your desktop worker.env after setup:
#   %APPDATA%\immersive-studio\worker.env  (Windows)
#
# Generate packs with Import target = Godot 4, Tripo textures ON, mesh ON.

STUDIO_TRIPO_API_KEY=
STUDIO_MESH_PROVIDER=tripo
STUDIO_TEXTURE_SOURCE=tripo
STUDIO_TRIPO_TEXTURE=1
STUDIO_TRIPO_PBR=1
STUDIO_EXPORT_MESH_DEFAULT=1
STUDIO_MESH_FALLBACK=1

# Optional: decimate Tripo meshes to spec poly_budget_tris (requires Blender on PATH or STUDIO_BLENDER_BIN)
STUDIO_MESH_POSTPROCESS=1
STUDIO_MESH_COLLIDER_EXPORT=1
# STUDIO_BLENDER_BIN=C:\Program Files\Blender Foundation\Blender 4.2\blender.exe

# Ollama for real specs (or use Mock mode in Studio UI)
# STUDIO_OLLAMA_URL=http://127.0.0.1:11434
# STUDIO_OLLAMA_MODEL=llama3.2
